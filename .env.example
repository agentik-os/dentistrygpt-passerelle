# DentistryGPT Passerelle Desktop - Environment Variables

# API base URL (defaults to production if not set)
VITE_DENTISTRYGPT_API_URL=https://www.dentistrygpt.com

# Clerk publishable key for authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx

# JWT secret for passerelle auth (generate with: openssl rand -base64 32)
PASSERELLE_JWT_SECRET=
